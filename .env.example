# ── Server ──────────────────────────────────────────────
SERVER_PORT=4317

# ── LLM Provider ────────────────────────────────────────
# Main LLM is configured in the Settings UI (gear button).
# Pick a provider (Anthropic, OpenAI, MiMo, OpenRouter, Nemotron, Custom)
# and paste your API key in the Settings panel. No env vars needed for the brain.

# ── Groq (free — break-room chatter & fallback) ────────
# Get a free key at https://console.groq.com/keys
# Can also be set in Settings UI
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Jira (optional — Project Manager agent) ────────────
JIRA_BASE_URL=https://your-site.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=

# ── Zoom server-to-server OAuth (optional — recordings) ─
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# ── Email / SMTP (optional — Outreach agent) ───────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# ── Spotify (optional — DJ feature, needs Premium) ─────
# Create app at https://developer.spotify.com/dashboard
# Add redirect URI, then visit /api/spotify/login once.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:4317/api/spotify/callback

# ── Optional ───────────────────────────────────────────
HF_TOKEN=
GITHUB_TOKEN=
